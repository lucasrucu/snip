# Supabase (snip's own project — separate from the Financial Dashboard)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Optional — the public redirect uses the resolve_link RPC, so the service role
# key is not required. Leave blank unless you add server-only admin operations.
SUPABASE_SERVICE_ROLE_KEY=

# Canonical short-link domain shown in the dashboard (NOT localhost).
# Set this to https://qori.click in BOTH .env.local and Vercel. If unset, the code
# defaults to https://qori.click anyway — just never set it to a localhost URL.
NEXT_PUBLIC_SITE_URL=https://qori.click

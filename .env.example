# Supabase (snip's own project — separate from the Financial Dashboard)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Optional — the public redirect uses the resolve_link RPC, so the service role
# key is not required. Leave blank unless you add server-only admin operations.
SUPABASE_SERVICE_ROLE_KEY=

# Base URL used to display generated short links.
# Local dev: http://localhost:3000   Production: https://qori.click
NEXT_PUBLIC_SITE_URL=http://localhost:3000
